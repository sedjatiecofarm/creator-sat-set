AI_PROVIDER=gemini
AI_PROVIDER_ORDER=gemini,openrouter,groq
GEMINI_API_KEY=isi_api_key_gemini_kamu_di_sini
GEMINI_MODEL=gemini-2.5-flash-lite

# Fallback OpenRouter free models:
OPENROUTER_API_KEY=isi_api_key_openrouter_kamu_di_sini
OPENROUTER_MODEL=openrouter/free
# Opsional kalau mau pakai daftar model gratis tertentu:
# OPENROUTER_MODELS=openrouter/free,qwen/qwen3-235b-a22b:free,deepseek/deepseek-r1-0528:free,deepseek/deepseek-chat-v3-0324:free,google/gemma-3-27b-it:free

# Fallback Groq:
GROQ_API_KEY=isi_api_key_groq_kamu_di_sini
GROQ_MODEL=llama-3.3-70b-versatile

# Opsional kalau mau pakai OpenAI:
OPENAI_API_KEY=isi_api_key_openai_kamu_di_sini
OPENAI_MODEL=gpt-4.1-mini

PORT=8787

# Cloud database untuk deployment:
SUPABASE_URL=https://project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=isi_publishable_atau_anon_key_supabase
SUPABASE_SERVICE_ROLE_KEY=isi_service_role_key_supabase
SUPABASE_TABLE=creator_app_state
SUPABASE_STATE_ID=creator-sat-set
